# local-terminal-mcp — environment configuration
#
# Under the .mcpb install model (v1.11.0+), this plugin runs via Claude Desktop's
# built-in stdio transport. HTTP transport, MCP_PORT, and MCP_AUTH_TOKEN are no
# longer used and have been removed.
#
# All configuration is handled through Claude Desktop's user_config UI.
# The only optional variable is ANTHROPIC_API_KEY, set there — not here.
#
# If you are building from source and want to set environment variables for
# local development, create a .env file (excluded from .mcpbignore and .gitignore)
# with the variables below.

# Optional: enables AI-assisted safety classification on every run_command invocation.
# Obtain from https://console.anthropic.com — starts with sk-ant-
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: operator-level override to demote a specific binary+category from RED to
# AI-reviewed. Format: "binary:category" — e.g. "pip:pkg-install"
# Disabled by default. Use only if you understand the security implications.
# BYPASS_BINARIES=

# Optional: controls AI layer failure behavior.
# false (default) = skip AI layer on failure, fall back to manual confirmation
# true = block the command if AI classification fails
# LAYER_STRICT_MODE=false
